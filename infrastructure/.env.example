# =============================================================================
# AWS Configuration
# =============================================================================

# AWS Region for infrastructure deployment
AWS_REGION=eu-north-1

# AWS Profile (optional - if not using default credentials)
# AWS_PROFILE=your-profile-name

# =============================================================================
# Terraform Backend Configuration
# =============================================================================

# S3 bucket for Terraform state (will be created by bootstrap script)
TF_STATE_BUCKET=access-manager-terraform-state-YOUR-ACCOUNT-ID

# DynamoDB table for state locking
TF_LOCK_TABLE=terraform-state-lock

# =============================================================================
# Cognito Configuration
# =============================================================================

# Callback URLs for OAuth (comma-separated)
COGNITO_CALLBACK_URLS=http://localhost:3000/api/auth/callback/cognito

# Sign-out URLs for OAuth (comma-separated)
COGNITO_LOGOUT_URLS=http://localhost:3000

# Cognito domain prefix (must be globally unique)
COGNITO_DOMAIN_PREFIX=access-manager-auth-YOUR-UNIQUE-SUFFIX

# =============================================================================
# Amplify Configuration
# =============================================================================

# Git repository URL
AMPLIFY_REPOSITORY_URL=https://github.com/your-username/access-manager

# Git provider access token (GitHub, GitLab, Bitbucket)
AMPLIFY_ACCESS_TOKEN=your-git-access-token

# Branch to deploy
AMPLIFY_BRANCH_NAME=main

# Custom domain (optional)
# AMPLIFY_CUSTOM_DOMAIN=your-domain.com

# =============================================================================
# Secrets and Configuration
# =============================================================================

# Additional secrets to store in Secrets Manager (JSON format)
# SECRETS_JSON={"api-key":"your-api-key","secret-token":"your-token"}

# Additional parameters to store in Parameter Store (JSON format)
# PARAMETERS_JSON={"feature-flag":"true","config-value":"123"}

# =============================================================================
# Application Configuration
# =============================================================================

# Project name
PROJECT_NAME=access-manager

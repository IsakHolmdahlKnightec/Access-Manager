.opencode/opencode.jsonc

# =============================================================================
# Amplify
# =============================================================================

# Amplify hosting build artifacts
.amplify-hosting/

# =============================================================================
# Terraform
# =============================================================================

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local dev
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore Terraform plan output
*.tfplan

# =============================================================================
# Infrastructure
# =============================================================================

# Environment files
infrastructure/.env
.env

# Local development files
infrastructure/.terraform.lock.hcl
